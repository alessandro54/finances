# Dev-only image: runs the SvelteKit dev server with HMR inside docker-compose,
# using Bun as the package manager + runtime. Production deploys to Vercel.
FROM oven/bun:1-alpine
WORKDIR /app

# Install deps first for layer caching. Source is bind-mounted at runtime;
# node_modules lives in an anonymous volume so the host dir doesn't clobber it.
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY . .

EXPOSE 5173
CMD ["bun", "run", "dev", "--", "--host", "0.0.0.0"]
