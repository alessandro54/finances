# Root env for docker-compose. Copy to .env and fill in.
# Shared by the api and web services (and n8n timezone).

# Turso (libSQL) — the DB n8n writes to and the API reads
TURSO_DATABASE_URL=libsql://n8n-finances-<org>.turso.io
TURSO_AUTH_TOKEN=eyJ...

# Bearer token: the web dash (and future LLM) must send Authorization: Bearer <API_TOKEN>
# Must be the same value used by both api and web.
API_TOKEN=change-me-long-random

# Optional
TZ=America/Lima
